{
  "name": "rein",
  "version": "0.1.0",
  "description": "Agent-native layer on top of GitHub commits",
  "type": "module",
  "bin": {
    "agentgit": "./dist/cli.js",
    "rein": "./dist/cli.js"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "build:cli": "tsc -p tsconfig.cli.json",
    "dev:api": "tsx watch src/server.ts",
    "start:api": "node dist/server.js",
    "cli": "tsx src/cli.ts",
    "agentgit": "tsx src/cli.ts",
    "db:setup": "node scripts/setup-db.mjs 001_agent_commits.sql",
    "db:migrate:title": "node scripts/setup-db.mjs 003_add_title.sql",
    "db:migrate:repo": "node scripts/setup-db.mjs 004_add_repo.sql",
    "benchmark": "node scripts/benchmark-agentgit.mjs",
    "backboard:smoke": "node scripts/backboard-smoke.mjs",
    "backfill": "tsx src/cli.ts backfill"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@supabase/server": "^1.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "backboard-sdk": "^1.5.15",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.0",
    "next": "^16.2.9",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
